# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://resolveai:resolveai@localhost:5432/resolveai
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=resolveai
POSTGRES_DB=resolveai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Groq (fallback LLM) ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# ── Ollama (local fallback) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3:8b

# ── Twilio (WhatsApp channel) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── AWS (Email channel) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
SES_FROM_EMAIL=support@example.com

# ── Langfuse (observability) ───────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# ── Admin UI ──────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Semantic cache ────────────────────────────────────────────────────────────
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.97
SEMANTIC_CACHE_TTL_HOURS=24

# ── LLM circuit breaker ───────────────────────────────────────────────────────
LLM_CIRCUIT_BREAKER_FAILURES=3
LLM_CIRCUIT_BREAKER_WINDOW_SECONDS=60
LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300